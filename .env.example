# Lamia Learn English Environment Example
# Copy file ini menjadi .env.local untuk development lokal.

# Neon PostgreSQL / PostgreSQL connection string
# Format Neon umum: postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/lamia_learn_english?sslmode=require"

# Optional: direct connection URL untuk Prisma migrate/db push jika memakai Neon pooler.
# Jika tidak punya DIRECT_URL, samakan dengan DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/lamia_learn_english?sslmode=require"

# Vercel Blob token untuk upload gambar/audio/dokumen materi
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxx"

# Session secret untuk cookie login asli. Gunakan string acak minimal 32 karakter.
SESSION_SECRET="ganti-dengan-secret-random-minimal-32-karakter"
AUTH_SECRET="ganti-dengan-secret-random-minimal-32-karakter"

# URL dan nama aplikasi
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Lamia Learn English"

# Akun awal seed database
SEED_SUPERADMIN_EMAIL="admin@lamia.local"
SEED_SUPERADMIN_PASSWORD="Admin12345!"
SEED_TEACHER_EMAIL="guru@lamia.local"
SEED_TEACHER_PASSWORD="Guru12345!"
SEED_STUDENT_EMAIL="murid@lamia.local"
SEED_STUDENT_PASSWORD="Murid12345!"

# Fitur speaking berbasis browser SpeechRecognition di client.
NEXT_PUBLIC_ENABLE_SPEAKING_QUIZ="true"
